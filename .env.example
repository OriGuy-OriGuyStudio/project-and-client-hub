# ============================================================
# Studio Ori Guy — Client Portal environment variables
# Copy to `.env` and fill in. VITE_* are exposed to the client
# bundle; never put server secrets in a VITE_ var.
# ============================================================

# Supabase (from your project's API settings)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin identity — env-locked, cannot be changed from the UI
VITE_ADMIN_EMAIL=origuy@origuystudio.com

# Floating AI assistant (standalone iframe, no data passed in)
VITE_AI_CHAT_URL=https://studio-ori-guy-chatbot-pixel.vercel.app/

# WhatsApp deep-link number (international format, no +)
VITE_STUDIO_WHATSAPP=9720547520899

# ------------------------------------------------------------
# Server-side ONLY — set these as Supabase Edge Function secrets,
# NOT here and NEVER with a VITE_ prefix.
#   RESEND_API_KEY=...
#   CRON_SECRET=...
# ------------------------------------------------------------
