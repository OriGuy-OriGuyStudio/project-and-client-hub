{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/spec-pdf.ts": {
      "memory": 1769,
      "maxDuration": 60,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
